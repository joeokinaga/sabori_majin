<div class="container mt-5">
    <h1 class="text-center">個人成績レポート</h1>
    <div class="row">
        <!-- 達成率 -->
        <div class="col-md-4">
            <h2 class=" mt-4">達成率 (%)</h2>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>期間</th>
                        <th>達成率</th>
                    </tr>
                </thead>
                <tbody>
                    <% {
        '今日' => @completation_rate_today,
        '今週' => @completation_rate_week,
        '今月' => @completation_rate_month,
        '今年' => @completation_rate_year,
        '全期間' => @completation_rate_all
      }.each do |label, rate| %>
                    <tr>
                        <td><%= label %></td>
                        <td><%= rate %> %</td>
                    </tr>
                    <% end %>
                </tbody>
            </table>
            <!-- 合計誤差 -->
            <h2 class="mt-5">誤差合計</h2>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>期間</th>
                        <th>合計時間</th>
                    </tr>
                </thead>
                <tbody>
                    <% {
        '今日' => @total_error_today,
        '今週' => @total_error_week,
        '今月' => @total_error_month,
        '今年' => @total_error_year,
        '全期間' => @total_error_all
      }.each do |label, seconds| %>
                    <tr>
                        <td><%= label %></td>
                        <td>
                            <%= (seconds / 3600).floor %>時間
                            <%= ((seconds % 3600) / 60).floor %>分
                        </td>
                    </tr>
                    <% end %>
                </tbody>
            </table>
        </div>

        <!-- 合計学習時間 -->
        <div class="col-md-4">
            <h2 class="mt-5">総学習時間</h2>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>期間</th>
                        <th>合計時間</th>
                    </tr>
                </thead>
                <tbody>
                    <% {
        '今日' => @total_time_today,
        '今週' => @total_time_week,
        '今月' => @total_time_month,
        '今年' => @total_time_year,
        '全期間' => @total_time_all
      }.each do |label, seconds| %>
                    <tr>
                        <td><%= label %></td>
                        <td>
                            <%= (seconds / 3600).floor %>時間
                            <%= ((seconds % 3600) / 60).floor %>分
                        </td>
                    </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
        <div class="container mt-5 col-md-4">
            <h1>タスク一覧</h1>

            <!-- スクロール可能なカード -->
            <div class="card mt-4" style="max-height: 400px; overflow-y: auto;">
                <div class="card-body">
                    <% @tasks_all.each do |task| %>
                    <div class="border-bottom mb-3 pb-2">
                        <h5 class="card-title"><%= task.title %></h5>
                        <p class="card-text"><%= task.content %></p>
                        <p class="mb-0">
                            <strong>ステータス:</strong> <%= task.status %> |
                            <strong>予定開始:</strong> <%= task.planned_start_at.strftime("%Y-%m-%d %H:%M") %> |
                            <strong>予定終了:</strong> <%= task.planned_finish_at.strftime("%Y-%m-%d %H:%M") %> |
                            <strong>実開始:</strong> <%= task.started_at ? task.started_at.strftime("%Y-%m-%d %H:%M") : "-" %> |
                            <strong>実終了:</strong> <%= task.finished_at ? task.finished_at.strftime("%Y-%m-%d %H:%M") : "-" %>
                        </p>
                    </div>
                    <% end %>
                    <% if @tasks_today.empty? %>
                    <p>今日のタスクはありません。</p>
                    <% end %>
                </div>
            </div>
        </div>
    </div>
</div>