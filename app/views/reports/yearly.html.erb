<div class="container-fluid mt-5">
    <div class="text-center">
        <h1>Yearly Report</h1>
        <%= link_to "Daily", daily_reports_path, class: "btn #{current_page?(daily_reports_path) ? 'btn-secondary' : 'btn-primary'}" %>
        <%= link_to "Weekly", weekly_reports_path, class: "btn #{current_page?(weekly_reports_path) ? 'btn-secondary' : 'btn-primary'}" %>
        <%= link_to "Monthly", monthly_reports_path, class: "btn #{current_page?(monthly_reports_path) ? 'btn-secondary' : 'btn-primary'}" %>
        <%= link_to "Yearly", yearly_reports_path, class: "btn #{current_page?(yearly_reports_path) ? 'btn-secondary' : 'btn-primary'}" %>
        <%= link_to "All", all_reports_path, class: "btn #{current_page?(all_reports_path) ? 'btn-secondary' : 'btn-primary'}" %>
    </div>
    <div class="row align-items-baseline">
        <div class="col-md-3 text-center">
            <h4 class="mt-5">今年の合計時間(h)</h4>
            <!-- Note: This chart will need different data (per month) -->
            <canvas id="myChart3"></canvas>
            <p class="h5 mt-3">
                計: <%= (@total_time_year / 3600).floor %> 時間 <%= ((@total_time_year % 3600) / 60).floor %>分
            </p>

            <h4 class="mt-5">タスクのステータス</h4>
            <div style="height: 250px; width: 250px; margin: auto;">
                <canvas id="myChart4"></canvas>
            </div>
        </div>

        <div class="col-md-6 d-flex flex-column align-items-center align-self-center">
            <h2 class="mt-4">達成率 (%)</h2>
            <canvas id="myChart1"></canvas>
            <ul class="list-group mt-3" style="max-width: 300px;">
                <li class="list-group-item d-flex justify-content-between align-items-center fw-bold">
                    達成率:
                    <span class=" fs-6">
                        <%= @completion_rate_year %> %
                    </span>
                </li>
            </ul>
        </div>

        <div class="col-md-3">
            <h4>タスク一覧</h4>
            <div class="card mt-4" style="max-height: 400px; overflow-y: auto;">
                <div class="card-body">
                    <% @tasks_year.each do |task| %>
                    <div class="border-bottom mb-3 pb-2">
                        <h5 class="card-title"><%= task.title %></h5>
                        <p class="card-text"><%= task.content %></p>
                        <p class="mb-0"><strong>ステータス:</strong> <%= task.status %> </p>
                        <p class="mb-0"><strong>予定開始:</strong> <%= task.planned_start_at.strftime("%Y-%m-%d %H:%M") %></p>
                        <p class="mb-0"><strong>予定終了:</strong> <%= task.planned_finish_at.strftime("%Y-%m-%d %H:%M") %></p>
                        <p class="mb-0"><strong>実開始:</strong> <%= task.started_at ? task.started_at.strftime("%Y-%m-%d %H:%M") : "-" %></p>
                        <p class="mb-0"><strong>実終了:</strong> <%= task.finished_at ? task.finished_at.strftime("%Y-%m-%d %H:%M") : "-" %></p>
                    </div>
                    <% end %>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener("turbo:load", function() {

  const charts = [
    {
		id: 'myChart1',
		// 1. グラフの種類を 'pie' に変更
		type: 'pie',
		data: {
			// 2. ラベルを各データに対応させる（例：「達成」「未達成」）
			labels: ['達成', '未達成'],
			datasets: [{
			label: '達成率 (%)',
			// 3. データを配列で渡す（達成率と未達成率）
			data: <%= [(@completion_rate_year || 0), 100 - (@completion_rate_year || 0)] %>,
			// 4. 各データの色を配列で指定
			backgroundColor: [
				'rgba(54, 162, 235, 0.5)', // 達成部分の色
				'rgba(255, 99, 132, 0.5)'  // 未達成部分の色
			],
			borderColor: [
				'rgba(54, 162, 235, 1)',
				'rgba(255, 99, 132, 1)'
			],
			borderWidth: 1
			}]
		},
		options: {
			aspectRatio: 2
      }
	},
    {
      id: 'myChart2',
      type: 'bar',
      data: {
        labels: ["<%= @tasks_year.empty? ? "今日のタスクがありません" : @tasks_year.first.planned_start_at.strftime("%Y-%m-%d") %>"],
        datasets: [{
          label: "誤差時間合計(h)",
          data: [<%= (@total_error_year / 3600.0).round(1) %>],
          backgroundColor: 'rgba(54, 162, 235, 0.5)',
          borderColor: 'rgba(54, 162, 235, 1)',
          borderWidth: 1
        }]
      },
      options: {
        scales: {
          y: { min: 0, max: 100,  beginAtZero: true }
        }
      }
    },
    {
		id: 'myChart3',
		type: 'bar',
		data: {
			labels: ["1月", "2月", "3月", "4月", "5月", "6月", "7月", "8月", "9月", "10月", "11月", "12月"],
			datasets: [{
			label: "合計時間(h)",
			data: <%= @total_time_year_per_month_hours %>,
			backgroundColor: 'rgba(54, 162, 235, 0.5)',
			borderColor: 'rgba(54, 162, 235, 1)',
			borderWidth: 1
			}]
		},
		options: {
			scales: {
			y: { beginAtZero: true }
			}
		}
	},
	{
		id: 'myChart4',
		type: 'bar',
		data: {
				labels: <%=@tasks_status_year.each_index.map { |i| "#{i}月" }.to_json.html_safe%>,
				datasets: [
				{
					label: "unstarted",
					data: <%= @tasks_status_year.map { |month| month["unstarted"] || 0 }.to_json.html_safe %>,
					backgroundColor: 'rgba(54, 162, 235, 0.5)',
					borderColor: 'rgba(54, 162, 235, 1)',
					borderWidth: 1
				},
				{
					label: "working",
					data: <%= @tasks_status_year.map { |month| month["working"] || 0 }.to_json.html_safe %>,
					backgroundColor: 'rgba(255, 99, 132, 0.5)',
					borderColor: 'rgba(255, 99, 132, 1)',
					borderWidth: 1
				},
				{
					label: "stopped",
					data: <%= @tasks_status_year.map { |month| month["stopped"] || 0 }.to_json.html_safe %>,
					backgroundColor: 'rgba(255, 206, 86, 0.5)',
					borderColor: 'rgba(255, 206, 86, 1)',
					borderWidth: 1
				},
				{
					label: "done",
					data: <%= @tasks_status_year.map { |month| month["done"] || 0 }.to_json.html_safe %>,
					backgroundColor: 'rgba(75, 192, 192, 0.5)',
					borderColor: 'rgba(75, 192, 192, 1)',
					borderWidth: 1
				}
				]
			},
			options: {
			responsive: true,
			maintainAspectRatio: false, // デフォルトの比率を無視
			aspectRatio: 1,             // 正方形にする（1:1）
			scales: {
				x: { stacked: true },
				y: { stacked: true, beginAtZero: true }
			}
			}
	}
  ];

  charts.forEach(c => {
    const ctx = document.getElementById(c.id);
    if (!ctx) return;

    // 既存のグラフを破棄
    if (ctx.chart) ctx.chart.destroy();

    // 新しいグラフを作成
    ctx.chart = new Chart(ctx.getContext('2d'), {
      type: c.type,
      data: c.data,
      options: c.options
    });
  });

});
</script>
