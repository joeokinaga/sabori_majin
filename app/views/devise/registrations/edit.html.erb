<div class="container py-5" style="max-width:600px;">
  <div class="card shadow rounded">
    <div class="card-body">
      <h1 class="text-center fw-bold mb-4 mt-3" style="font-size:2.2rem;">プロフィール編集</h1>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="mb-3">
          <%= f.label :name, "名前", class: "form-label fw-bold" %>
          <%= f.text_field :name, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :email, "メールアドレス", class: "form-label fw-bold" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :password, "パスワード", class: "form-label fw-bold" %>
          <% if @minimum_password_length %>
            <small class="text-muted">（<%= @minimum_password_length %>文字以上）</small>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
          <small class="text-muted">パスワードを変更しない場合は空欄でOK</small>
        </div>

        <div class="mb-3">
          <%= f.label :password_confirmation, "パスワード（確認）", class: "form-label fw-bold" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :current_password, "現在のパスワード", class: "form-label fw-bold" %>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
          <small class="text-muted">変更を保存するには必須です</small>
        </div>

        <div class="d-flex justify-content-center gap-3 mt-4">
          <%= f.submit "更新", class: "btn btn-primary px-4" %>
          <%= link_to "キャンセル", root_path, class: "btn btn-secondary px-4" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
