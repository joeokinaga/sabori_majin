<div class="container my-5 py-5" style="max-width:900px;">
  <div style="position: relative;">
    <h1 class="fw-bold mb-5 text-center" style="font-size:2.4rem;">明日以降のタスク</h1>
    <div style="position: absolute; right: 0; top: 0;">
      <%= link_to "戻る", root_path, class: "btn btn-outline-secondary", style: "font-size:1rem;" %>
    </div>
  </div>

  <% if @tasks_by_date.present? %>
    <% @tasks_by_date.each do |date, tasks| %>
      <h2 class="fw-bold mt-5 mb-4 text-center" style="font-size:1.5rem;">
        <%= date.strftime('%Y年%m月%d日') %>
      </h2>

      <div class="d-flex flex-column align-items-center">
        <% tasks.each do |task| %>
          <div class="card mb-4 mx-auto" style="max-width:500px; min-width:320px; border:2px solid #222;">
            <div class="card-body px-4 py-3 position-relative">

              <!-- タイトルを中央寄せ -->
              <div class="text-center mb-2" style="font-size:1.35rem; font-weight:bold;">
                <%= link_to task.title, task_path(task), class: "text-dark", style: "text-decoration:none;" %>
              </div>

              <!-- ボタンは右端に縦に並べる -->
              <div style="position: absolute; top: 50%; right: 1rem; transform: translateY(-50%); display: flex; flex-direction: column; gap: 0.5rem;">
                <%= button_to task_path(task),
                              method: :delete,
                              class: "btn btn-sm fs-4",
                              data: { turbo: false },
                              onclick: "return confirm('本当に削除しますか？');" do %>
                  🗑️
                <% end %>

                <%= link_to edit_task_path(task),
                            class: "btn btn-sm fs-4",
                            title: "編集" do %>
                  ✏️
                <% end %>
              </div>

              <!-- 時間表示 -->
              <div class="text-center mt-4" style="font-size:1.1rem;">
                <%= "#{task.planned_start_at.strftime('%H:%M')}〜#{task.planned_finish_at.strftime('%H:%M')}" %>
              </div>

            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="text-center my-5" style="font-size:1.2rem;">明日以降のタスクはありません</div>
  <% end %>
</div>
