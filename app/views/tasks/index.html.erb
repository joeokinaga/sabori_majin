<div class="container my-5 py-5" style="max-width:1200px;">
  <h1 class="text-center fw-bold mb-5" style="font-size:3rem;">今日のタスク</h1>
  <div class="row justify-content-center align-items-start g-4">
    <!-- 中央: タスク一覧（カード使用） -->
    <div class="col-md-6 d-flex flex-column align-items-center">
      <% @tasks.each do |task| %>
        <% 
          now = Time.current.in_time_zone('Asia/Tokyo')
          border_color =
            if task.status == "done"
              "#28a745" # 緑
            elsif task.status == "stopped"
              "#ff0000" # 茶色
            elsif task.status == "unstarted"
              now > task.planned_finish_at ? "#ff0000" : "#222"
            else
              "#222"
            end
        %>
        <div class="card mb-4 shadow rounded w-100" style="max-width:520px; min-width:320px; border:2px solid <%= border_color %>;">
          <div class="card-body px-4 py-3">
            <div class="text-center fw-bold" style="font-size:1.35rem;">
              <%= link_to task.title, task_path(task), class: "text-dark text-decoration-none" %>
            </div>
            <div class="text-center mt-2 text-muted" style="font-size:1.1rem;">
              <%= "#{task.planned_start_at.strftime('%H:%M')}〜#{task.planned_finish_at.strftime('%H:%M')}" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    <!-- 右側: タスクの新規作成 -->
    <div class="col-md-3 d-flex flex-column justify-content-start align-items-center mt-4 mt-md-0">
      <%= link_to new_task_path, class: "btn btn-primary mb-4 w-100", style: "font-size:2rem; min-width:220px;" do %>
        新規タスク作成
      <% end %>
      <%= link_to future_tasks_path, class: "btn btn-outline-secondary mb-4 w-100", style: "font-size:1.5rem;" do %>
        明日以降のタスク
      <% end %>
      <%= link_to all_reports_path, class: "btn btn-outline-dark w-100 text-center", style: "font-size:1.5rem;" do %>
        個人成績
      <% end %>
    </div>
  </div>
</div>