<h1>タスク編集</h1>
<%= form_with(model: @task) do |f| %>
  <%= render 'shared/error_messages', object: f.object %>

  <%= f.label :title, "タスク名", class: "form-label" %>
  <%= f.text_field :title, class: "form-control" %>

  <%= f.label :content, "内容", class: "form-label" %>
  <%= f.text_area :content, class: "form-control", rows: 2 %>

  <label>予定時間</label>
  <div style="display: flex; gap: 8px;">

    <%= f.date_field :planned_date, class: "form-control", value: @task.planned_start_at&.to_date %>

    <%= f.number_field :start_hour, in: 0..23, class: "form-control", placeholder: "時", value: @task.planned_start_at&.hour %> :
    <%= f.number_field :start_minute, in: 0..59, class: "form-control", placeholder: "分", value: @task.planned_start_at&.min %> 〜

    <%= f.number_field :finish_hour, in: 0..23, class: "form-control", placeholder: "時", value: @task.planned_finish_at&.hour %> :
    <%= f.number_field :finish_minute, in: 0..59, class: "form-control", placeholder: "分", value: @task.planned_finish_at&.min %>
  </div>
  <%= f.submit "更新", class: "btn btn-primary" %>
<% end %>